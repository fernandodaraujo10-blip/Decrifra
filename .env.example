# ═══════════════════════════════════════════════════════
#  .env.example — Decifra App
#  Copie este arquivo para .env.local e preencha os valores.
#  ⚠️  NUNCA commite .env.local com valores reais no git!
# ═══════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────
# Firebase (configuração pública — segura para o frontend)
# Obtenha em: Firebase Console → Configurações do Projeto
# ────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ────────────────────────────────────────────────────────
# API KEYS SENSÍVEIS — NÃO ficam mais no frontend!
#
# As chaves Gemini, TMDB e OMDb foram migradas para o
# Firebase Secret Manager e só existem nas Cloud Functions.
#
# Para configurar no servidor, execute:
#   firebase functions:secrets:set GEMINI_API_KEY
#   firebase functions:secrets:set TMDB_API_KEY
#   firebase functions:secrets:set OMDB_API_KEY
# ────────────────────────────────────────────────────────
# (nenhuma variável VITE_ de chave sensível aqui)
